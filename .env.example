# ============================================================================
# Sharp Arena — environment template.
# Copy to .env and edit. Never commit .env.
# ============================================================================

# --- Postgres -----------------------------------------------------------------
POSTGRES_USER=arena
POSTGRES_PASSWORD=arena
POSTGRES_DB=sharp_arena
POSTGRES_PORT=5432

# --- Backend (ArenaApi) -------------------------------------------------------
ARENA_API_PORT=5000
ASPNETCORE_ENVIRONMENT=Development

# Connection string used by ArenaApi in Docker. host name `postgres` matches the
# compose service. For local dev (outside compose) override via user-secrets or
# appsettings.Development.json.
ConnectionStrings__Database=Host=postgres;Port=5432;Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD};Search Path=arena,public

# --- Frontend -----------------------------------------------------------------
FRONTEND_PORT=3000

# Build-time public env vars (must be passed as docker --build-arg, not runtime).
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
